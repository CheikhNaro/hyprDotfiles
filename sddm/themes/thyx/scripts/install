#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"
set -Eeuo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# shellcheck disable=SC1091
source "${script_dir}/lib/_constants.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_common.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_repo.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_theme.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_deps.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_sddm.sh"

# shellcheck disable=SC2034
THYX_LOG_PREFIX="thyx install"
THYX_REPO_DIR="$(_thyx_find_repo "${script_dir}")"

_thyx_print_install_plan() {
  _thyx_step "plan"
  _thyx_hr
  printf '%b\n' "${THYX_BOLD}thyx installer${THYX_NC}"
  _thyx_hr
  printf 'source:        %s\n' "${THYX_REPO_DIR}"
  printf 'theme id:      %s\n' "${THYX_THEME_ID}"
  printf 'theme dst:     %s\n' "${THYX_THEME_DST}"
  printf 'fonts dst:     %s\n' "${THYX_FONTS_DST}"
  printf 'sddm conf:     %s\n' "${THYX_SDDM_CONF}"
  printf 'sddm backup:   %s\n' "${THYX_SDDM_CONF_BACK}"
  _thyx_hr
  printf '%s\n' "will do:"
  printf '%s\n' "  - validate metadata.desktop MainScript and ConfigFile"
  printf '%s\n' "  - install missing runtime packages from the distro manifest"
  printf '%s\n' "  - verify required commands, greeter, and qml runtime modules"
  printf '%s\n' "  - install the theme through one atomic stage"
  printf '%s\n' "  - install bundled fonts when present"
  printf '%s\n' "  - backup /etc/sddm.conf once"
  printf '%s\n' "  - select thyx in /etc/sddm.conf"
  printf '%s\n' "  - enable sddm when systemctl exists"
  _thyx_hr
}

_thyx_enable_sddm_if_systemctl_exists() {
  command -v systemctl >/dev/null 2>&1 || return 0

  _thyx_step "systemd"
  if _thyx_run systemctl enable sddm.service; then
    _thyx_ok "sddm enabled"
    return 0
  fi

  _thyx_warn "could not enable sddm.service"
}

_thyx_verify_install() {
  local current
  local config_file

  _thyx_step "verify"
  _thyx_validate_repo_tree "${THYX_THEME_DST}"

  current="$(_thyx_theme_current_from_file "${THYX_SDDM_CONF}")"
  [ "${current}" = "${THYX_THEME_ID}" ] || _thyx_die "${THYX_SDDM_CONF} selects ${current:-empty}, expected ${THYX_THEME_ID}"

  config_file="$(_thyx_meta_get ConfigFile "${THYX_THEME_DST}/metadata.desktop")"
  [ "${config_file}" = "theme.conf" ] || _thyx_die "ConfigFile is ${config_file:-empty}, expected theme.conf"
  [ -f "${THYX_THEME_DST}/${config_file}" ] || _thyx_die "ConfigFile missing: ${THYX_THEME_DST}/${config_file}"

  if grep -RIn 'themes/.*\.conf' "${THYX_THEME_DST}/metadata.desktop" "${THYX_THEME_DST}/theme.conf" "${THYX_THEME_DST}/src" >/dev/null 2>&1; then
    grep -RIn 'themes/.*\.conf' "${THYX_THEME_DST}/metadata.desktop" "${THYX_THEME_DST}/theme.conf" "${THYX_THEME_DST}/src" || true
    _thyx_die "installed theme still references themes/*.conf"
  fi

  if _thyx_source_has_fonts; then
    [ -d "${THYX_FONTS_DST}" ] || _thyx_die "fonts directory missing: ${THYX_FONTS_DST}"
  fi

  _thyx_ok "install verified"
}

_thyx_print_install_hints() {
  local greeter

  greeter="$(_thyx_find_one_command sddm-greeter-qt6 sddm-greeter)"

  printf '\n'
  _thyx_hr
  printf '%s\n' "safe test command:"
  printf '  QT_QPA_PLATFORM=xcb %s --test-mode --theme %s\n' "${greeter}" "${THYX_THEME_DST}"
  printf '%s\n' "when you're ready, restart sddm from a tty:"
  printf '%s\n' "  sudo systemctl restart sddm"
  _thyx_hr
}

main() {
  trap _thyx_on_err ERR

  _thyx_parse_args "$@"
  _thyx_setup_log
  _thyx_validate_repo_tree "${THYX_REPO_DIR}"
  [ "$(_thyx_os_field ID || true)" != "nixos" ] || _thyx_die "NixOS install is declarative; use docs/nix.md. The uninstaller is not supported on NixOS."
  _thyx_prepare_runtime_manifest "${script_dir}" >/dev/null

  _thyx_print_install_plan
  _thyx_confirm "proceed? type y to install"
  _thyx_sudo_warmup

  _thyx_install_runtime_deps "${script_dir}"
  _thyx_check_install_deps "${script_dir}"

  _thyx_install_theme_atomic
  _thyx_install_fonts
  _thyx_select_sddm_theme
  _thyx_enable_sddm_if_systemctl_exists
  _thyx_verify_install
  _thyx_print_install_hints

  _thyx_step "done"
  _thyx_ok "install finished"
}

main "$@"
