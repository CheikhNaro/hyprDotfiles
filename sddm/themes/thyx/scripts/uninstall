#!/usr/bin/env bash
[ -n "${BASH_VERSION:-}" ] || exec bash "$0" "$@"
set -Eeuo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# shellcheck disable=SC1091
source "${script_dir}/lib/_constants.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_common.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_repo.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_theme.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_deps.sh"
# shellcheck disable=SC1091
source "${script_dir}/lib/_sddm.sh"

# shellcheck disable=SC2034
THYX_LOG_PREFIX="thyx uninstall"
THYX_REPO_DIR="$(_thyx_find_repo "${script_dir}")"

_thyx_print_uninstall_plan() {
  _thyx_step "plan"
  _thyx_hr
  printf '%b\n' "${THYX_BOLD}thyx uninstaller${THYX_NC}"
  _thyx_hr
  printf 'repo:          %s\n' "${THYX_REPO_DIR}"
  printf 'theme id:      %s\n' "${THYX_THEME_ID}"
  printf 'theme dst:     %s\n' "${THYX_THEME_DST}"
  printf 'fonts dst:     %s\n' "${THYX_FONTS_DST}"
  printf 'sddm conf:     %s\n' "${THYX_SDDM_CONF}"
  printf 'sddm backup:   %s\n' "${THYX_SDDM_CONF_BACK}"
  _thyx_hr
  printf '%s\n' "will do:"
  printf '%s\n' "  - restore /etc/sddm.conf.thyx-back when present"
  printf '%s\n' "  - otherwise remove Current=thyx from /etc/sddm.conf"
  printf '%s\n' "  - remove installed theme files"
  printf '%s\n' "  - remove installed fonts"
  _thyx_hr
}

_thyx_verify_uninstall() {
  local current

  _thyx_step "verify"

  [ ! -d "${THYX_THEME_DST}" ] || _thyx_warn "theme dir still exists: ${THYX_THEME_DST}"
  [ ! -d "${THYX_FONTS_DST}" ] || _thyx_warn "fonts dir still exists: ${THYX_FONTS_DST}"
  [ ! -e "${THYX_THEME_STAGE}" ] || _thyx_warn "stage dir still exists: ${THYX_THEME_STAGE}"
  [ ! -e "${THYX_THEME_PREVIOUS}" ] || _thyx_warn "previous dir still exists: ${THYX_THEME_PREVIOUS}"

  current="$(_thyx_theme_current_from_file "${THYX_SDDM_CONF}" || true)"
  if [ "${current}" = "${THYX_THEME_ID}" ]; then
    _thyx_warn "${THYX_SDDM_CONF} still selects ${THYX_THEME_ID}"
    return 0
  fi

  _thyx_ok "sddm no longer selects ${THYX_THEME_ID}"
}

_thyx_print_uninstall_hints() {
  printf '\n'
  _thyx_hr
  printf '%s\n' "when you're ready, restart sddm from a tty:"
  printf '%s\n' "  sudo systemctl restart sddm"
  _thyx_hr
}

main() {
  trap _thyx_on_err ERR

  _thyx_parse_args "$@"
  _thyx_setup_log
  _thyx_validate_repo_tree "${THYX_REPO_DIR}"
  _thyx_check_uninstall_deps "${script_dir}"

  _thyx_print_uninstall_plan
  _thyx_confirm "proceed? type y to uninstall"
  _thyx_sudo_warmup

  _thyx_remove_sddm_selection
  _thyx_remove_theme_files
  _thyx_remove_fonts
  _thyx_verify_uninstall
  _thyx_print_uninstall_hints

  _thyx_step "done"
  _thyx_ok "uninstall finished"
}

main "$@"
