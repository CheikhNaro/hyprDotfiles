[Unit]
Description=Dwindle clockwise split enforcer for Hyprland
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
Environment=WAYLAND_DISPLAY=wayland-1
Environment=XDG_RUNTIME_DIR=/run/user/%U
ExecStartPre=/bin/sh -c 'until [ -S "${XDG_RUNTIME_DIR}/hypr" ] || [ -d "${XDG_RUNTIME_DIR}/hypr" ]; do sleep 0.5; done'
ExecStart=/usr/bin/bash %h/.config/hypr/scripts/dwindle-clockwise.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
